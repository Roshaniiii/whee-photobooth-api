# Whee Photobooth API — environment (copy to .env)

# development | production
ENVIRONMENT=development

# Comma-separated frontend origins (no trailing slash). Required in production.
# Example: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Max decoded JPEG size in bytes (default 5 MB)
MAX_IMAGE_BYTES=5242880

# Reject images wider/taller than this before processing
MAX_IMAGE_DIMENSION=4096

# Output width caps
PREVIEW_MAX_WIDTH=640
FULL_MAX_WIDTH=1280

# JPEG output quality (1–100)
JPEG_QUALITY_PREVIEW=75
JPEG_QUALITY_FULL=90

# Per-IP rate limit for POST /apply-filter (slowapi format)
RATE_LIMIT=300/minute
